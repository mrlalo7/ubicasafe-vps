# === UBICASAFE RAG Backend ===
# Copia este archivo como .env y rellena los valores

# PostgreSQL (con pgvector)
DATABASE_URL=postgresql+asyncpg://ubicasafe_user:CAMBIA_ESTA_CONTRASEÑA@localhost:5432/ubicasafe_db

# Gemini API
GEMINI_API_KEY=tu_api_key_de_gemini_aqui
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
GENERATION_MODEL=gemini-2.5-flash-lite
LIVE_MODEL=gemini-3.1-flash-live-preview
TTS_MODEL=gemini-3.1-flash-tts-preview
# Voz Gemini Live. Aoede suena mas ligera/natural; Kore es mas firme.
LIVE_VOICE_NAME=Aoede

# CORS - Orígenes permitidos (separados por coma)
# TODO(security): En producción, restringir a dominios específicos
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
RATE_LIMIT=30/minute
